---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import HeroSection from '../../components/HeroSection.astro';
import ProjectsStrip from '../../components/ProjectsStrip.astro';
import TimelineFeed from '../../components/TimelineFeed.astro';
import TagFilter from '../../components/TagFilter.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('en', ({ data }) => !data.draft);
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<Base title="Writing" lang="en">
  <Nav lang="en" currentPath="/en/" />
  <main>
    <HeroSection lang="en" postCount={posts.length} />
    <ProjectsStrip lang="en" />
    <div class="feed-header">
      <h2 class="feed-title">Writing</h2>
      <span class="feed-sub">Thoughts on engineering, AI, and shipping software</span>
    </div>
    <TagFilter tags={allTags} lang="en" />
    <TimelineFeed posts={posts} lang="en" />
  </main>
  <footer>
    Built with Astro ·
    <a href="https://github.com/encoreshao" target="_blank" rel="noopener">GitHub</a> ·
    <a href="https://icmoc.com" target="_blank" rel="noopener">icmoc.com</a>
  </footer>
</Base>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 56px 40px;
    position: relative;
    z-index: 1;
  }
  .feed-header {
    display: flex; align-items: baseline; gap: 12px;
    margin-bottom: 20px;
  }
  .feed-title {
    font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.5);
    letter-spacing: 2px; text-transform: uppercase;
  }
  .feed-sub { font-size: 12px; color: rgba(255,255,255,0.2); }
  footer {
    text-align: center; padding: 40px 24px;
    font-size: 12px; color: rgba(255,255,255,0.2);
    border-top: 1px solid rgba(255,255,255,0.06);
    position: relative; z-index: 1;
  }
  footer a { color: var(--cyan); text-decoration: none; }
</style>
