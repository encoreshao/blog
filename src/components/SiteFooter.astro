---
interface Props {
  lang: 'en' | 'zh';
}
const { lang } = Astro.props;

const year = new Date().getFullYear();

const t = {
  en: {
    thanks: 'Thanks for reading.',
    note: 'I write about AI systems, Rails engineering, and the craft of building things that actually ship — from Shanghai, since 2011.',
    links: [
      { label: '← All Articles', href: '/en/', external: false },
      { label: 'GitHub', href: 'https://github.com/encoreshao', external: true },
      { label: 'icmoc.com', href: 'https://icmoc.com', external: true },
      { label: 'RSS', href: '/rss.xml', external: false },
      { label: '中文版', href: '/zh/', external: false },
    ],
    byline: `Encore Shao · Shanghai, China · © ${year}`,
  },
  zh: {
    thanks: '感谢阅读。',
    note: '我在这里写 AI 系统、Rails 工程，以及真正能落地的产品构建——来自上海，始于 2011。',
    links: [
      { label: '← 所有文章', href: '/zh/', external: false },
      { label: 'GitHub', href: 'https://github.com/encoreshao', external: true },
      { label: 'icmoc.com', href: 'https://icmoc.com', external: true },
      { label: 'RSS', href: '/zh/rss.xml', external: false },
      { label: 'English', href: '/en/', external: false },
    ],
    byline: `邵壮 · 中国上海 · © ${year}`,
  },
} as const;

const c = t[lang];
---

<footer class="site-footer">
  <div class="footer-rule">
    <span class="rule-line"></span>
    <span class="rule-mark">✦</span>
    <span class="rule-line"></span>
  </div>

  <div class="footer-body">
    <p class="footer-thanks">{c.thanks}</p>
    <p class="footer-note">{c.note}</p>

    <nav class="footer-nav" aria-label="Footer navigation">
      {c.links.map((l, i) => (
        <>
          {i > 0 && <span class="nav-sep" aria-hidden="true">·</span>}
          <a
            href={l.href}
            class="nav-link"
            {...(l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {l.label}{l.external ? ' ↗' : ''}
          </a>
        </>
      ))}
    </nav>
  </div>

  <p class="footer-byline">{c.byline}</p>
</footer>

<style is:global>
  .site-footer {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 24px 48px;
  }

  /* ── Decorative rule ── */
  .site-footer .footer-rule {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    max-width: 560px;
    margin-bottom: 52px;
  }
  .site-footer .rule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0,212,255,0.25) 40%,
      rgba(168,85,247,0.2) 60%,
      transparent
    );
  }
  .site-footer .rule-mark {
    font-size: 12px;
    color: rgba(0,212,255,0.4);
    flex-shrink: 0;
    line-height: 1;
  }

  /* ── Body copy ── */
  .site-footer .footer-body {
    width: 100%;
    max-width: 520px;
    text-align: center;
    margin-bottom: 40px;
  }
  .site-footer .footer-thanks {
    font-size: clamp(22px, 4vw, 28px);
    font-weight: 800;
    color: rgba(255,255,255,0.9);
    letter-spacing: -0.3px;
    margin-bottom: 14px;
    line-height: 1.2;
  }
  .site-footer .footer-note {
    font-size: 14px;
    color: rgba(255,255,255,0.36);
    line-height: 1.75;
    margin-bottom: 32px;
  }

  /* ── Link row ── */
  .site-footer .footer-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 4px 2px;
  }
  .site-footer .nav-link {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.38);
    text-decoration: none;
    padding: 4px 10px;
    border-radius: 6px;
    transition: color 0.18s, background 0.18s;
  }
  .site-footer .nav-link:hover {
    color: var(--cyan);
    background: rgba(0,212,255,0.07);
  }
  .site-footer .nav-sep {
    color: rgba(255,255,255,0.12);
    font-size: 13px;
    padding: 0 2px;
    user-select: none;
  }

  /* ── Byline ── */
  .site-footer .footer-byline {
    font-size: 11px;
    color: rgba(255,255,255,0.16);
    letter-spacing: 0.3px;
    margin-top: 8px;
    text-align: center;
  }

  @media (max-width: 480px) {
    .site-footer { padding: 0 16px 36px; }
    .site-footer .footer-thanks { font-size: 20px; }
    .site-footer .footer-note { font-size: 13px; }
  }
</style>
