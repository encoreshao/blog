---
interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

const heading = lang === 'en' ? 'Projects' : '项目';
const subheading = lang === 'en'
  ? 'Things I built and still maintain'
  : '做的事，还在维护中';

const projects = [
  {
    name: 'bamboohr-mcp',
    tag: 'MCP · TypeScript',
    tagClass: 'tag-ai',
    desc: {
      en: 'MCP server wrapping BambooHR\'s API — lets any LLM query HR data in natural language.',
      zh: '将 BambooHR API 封装为 MCP Server，让任意 LLM 用自然语言查询 HR 数据。',
    },
    href: 'https://github.com/encoreshao/bamboohr-mcp',
    linkLabel: { en: 'GitHub', zh: 'GitHub' },
  },
  {
    name: 'Bookmark Dashboard',
    tag: 'Chrome · AI',
    tagClass: 'tag-chrome',
    desc: {
      en: 'Chrome extension that replaces new tab with an AI-powered full-featured bookmark manager.',
      zh: '用 AI 增强的全功能书签管理器替换 Chrome 新标签页。',
    },
    href: 'https://github.com/encoreshao/bookmark-dashboard',
    linkLabel: { en: 'GitHub', zh: 'GitHub' },
  },
  {
    name: 'RanBot',
    tag: 'AI Agents · Product',
    tagClass: 'tag-product',
    desc: {
      en: 'Multi-agent automation platform. Define workflows in natural language, let agents handle execution.',
      zh: '多 Agent 编排平台，用自然语言定义工作流，由 Agent 负责执行。',
    },
    href: 'https://ranbot.online',
    linkLabel: { en: 'ranbot.online', zh: 'ranbot.online' },
  },
  {
    name: 'china_regions',
    tag: 'Ruby · Open Source',
    tagClass: 'tag-ruby',
    desc: {
      en: 'Rails engine providing province/city/district models pre-loaded with official CN region data.',
      zh: 'Rails Engine，预装官方数据的省市区三级模型，零配置即用。',
    },
    href: 'https://github.com/encoreshao/china_regions',
    linkLabel: { en: 'GitHub', zh: 'GitHub' },
  },
] as const;
---

<section class="projects-section">
  <div class="section-header">
    <h2 class="section-title">{heading}</h2>
    <span class="section-sub">{subheading}</span>
  </div>
  <div class="projects-grid">
    {projects.map(p => (
      <a href={p.href} target="_blank" rel="noopener" class="project-card">
        <div class="project-top">
          <span class="project-name">{p.name}</span>
          <span class:list={['project-tag', p.tagClass]}>{p.tag}</span>
        </div>
        <p class="project-desc">{p.desc[lang]}</p>
        <div class="project-footer">
          <span class="project-link">
            {p.linkLabel[lang]}
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .projects-section { margin-bottom: 52px; }

  .section-header {
    display: flex; align-items: baseline; gap: 12px; margin-bottom: 20px;
  }
  .section-title {
    font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.5);
    letter-spacing: 2px; text-transform: uppercase;
  }
  .section-sub {
    font-size: 12px; color: rgba(255,255,255,0.2);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .project-card {
    display: flex; flex-direction: column;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 18px 20px;
    text-decoration: none;
    transition: all 0.22s;
    gap: 10px;
  }
  .project-card:hover {
    background: var(--glass-hover);
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.25);
  }

  .project-top {
    display: flex; flex-direction: column; gap: 6px;
  }
  .project-name {
    font-size: 14px; font-weight: 700; color: #fff;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }
  .project-tag {
    font-size: 10px; font-weight: 700;
    padding: 2px 8px; border-radius: 4px;
    letter-spacing: 0.4px; text-transform: uppercase;
    width: fit-content;
  }

  .project-desc {
    font-size: 12.5px; line-height: 1.6;
    color: rgba(255,255,255,0.42);
    flex: 1;
  }

  .project-footer { margin-top: 2px; }
  .project-link {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 600;
    color: rgba(255,255,255,0.3);
    transition: color 0.2s;
  }
  .project-card:hover .project-link { color: var(--cyan); }

  @media (max-width: 780px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
