---
interface Props {
  lang: 'en' | 'zh';
  postCount: number;
}

const { lang, postCount } = Astro.props;

const content = {
  en: {
    role: 'Full-stack Engineer & AI Researcher',
    bio: 'Full-stack engineer at Ekohe since 2011. I build AI-powered systems — LLM-integrated products, agentic workflows, and the data infrastructure that keeps them reliable. Open source author with a bias for shipping things that actually get used.',
    github: 'GitHub',
    linkedin: 'LinkedIn',
    site: 'icmoc.com',
    location: 'Shanghai, China',
  },
  zh: {
    role: '全栈工程师 & AI 研究员',
    bio: '2011 年起在 Ekohe 做全栈工程。专注构建 AI 驱动的系统——LLM 集成产品、Agentic 工作流，以及支撑它们可靠运行的数据基础设施。开源项目作者，偏好做真正被人使用的东西。',
    github: 'GitHub',
    linkedin: 'LinkedIn',
    site: 'icmoc.com',
    location: '中国·上海',
  },
} as const;

const skillGroups = [
  {
    label: lang === 'en' ? 'AI & Agents' : 'AI 与 Agent',
    type: 'ai',
    tags: ['LLM', 'AI Agents', 'MCP', 'RAG', 'pgvector', 'Multi-Agent'],
  },
  {
    label: lang === 'en' ? 'Engineering' : '工程',
    type: 'eng',
    tags: ['Ruby on Rails', 'Python', 'PostgreSQL', 'Redis', 'Sidekiq', 'REST API'],
  },
  {
    label: lang === 'en' ? 'Data & Analysis' : '数据与分析',
    type: 'data',
    tags: [lang === 'en' ? 'Data Pipeline' : '数据管道', lang === 'en' ? 'Data Quality' : '数据质量', 'ETL', lang === 'en' ? 'Analytics' : '数据分析'],
  },
];

const t = content[lang];
---

<section class="hero">
  <div class="hero-left">
    <div class="hero-body">
      <div class="hero-name">Encore Shao</div>
      <div class="hero-role">{t.role}</div>
      <p class="hero-bio">{t.bio}</p>
      <div class="hero-links">
        <a href="https://github.com/encoreshao" target="_blank" rel="noopener" class="hero-link link-github">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.603-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.03-2.682-.103-.253-.447-1.27.097-2.646 0 0 .84-.269 2.75 1.026A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.295 2.747-1.026 2.747-1.026.546 1.376.202 2.393.1 2.646.64.698 1.026 1.591 1.026 2.682 0 3.841-2.337 4.687-4.565 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          {t.github}
        </a>
        <a href="https://www.linkedin.com/in/encoreshao/" target="_blank" rel="noopener" class="hero-link link-linkedin">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          {t.linkedin}
        </a>
        <a href="https://icmoc.com" target="_blank" rel="noopener" class="hero-link link-site">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          {t.site}
        </a>
      </div>

      <div class="hero-skills">
        {skillGroups.map(group => (
          <div class="skill-group">
            <span class="group-label">{group.label}</span>
            <div class="skill-tags">
              {group.tags.map(tag => (
                <span class={`skill-tag tag-${group.type}`}>{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">{postCount}</span>
        <span class="stat-label">{lang === 'en' ? 'articles' : '篇文章'}</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-value">2</span>
        <span class="stat-label">{lang === 'en' ? 'languages' : '语言'}</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-value">10+</span>
        <span class="stat-label">{lang === 'en' ? 'years shipping' : '年经验'}</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-value">5+</span>
        <span class="stat-label">{lang === 'en' ? 'open source libs' : '开源项目'}</span>
      </div>
    </div>
  </div>

  <div class="hero-right">
    <div class="portrait-wrap">
      <div class="portrait-glow"></div>
      <div class="portrait-frame">
        <img
          src="https://raw.githubusercontent.com/encoreshao/encore/gh-pages/assets/images/encore.jpg"
          alt="Encore Shao"
          class="portrait-img"
        />
      </div>
      <div class="portrait-badge">
        <span class="badge-dot"></span>
        {t.location}
      </div>
    </div>
  </div>

</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 48px;
    align-items: center;
    margin-bottom: 56px;
    padding: 40px 0 36px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: relative;
    overflow-x: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: -60px; right: -80px;
    width: 520px; height: 520px;
    background: radial-gradient(circle at 60% 40%, rgba(0,212,255,0.09), transparent 65%);
    pointer-events: none;
  }

  /* ── Left column ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 40px;
    position: relative;
    z-index: 1;
  }

  .hero-name {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, #fff 30%, rgba(0,212,255,0.85));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 6px;
  }

  .hero-role {
    font-size: 14px;
    font-weight: 600;
    color: var(--cyan);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
    opacity: 0.85;
  }

  .hero-bio {
    font-size: 15px;
    line-height: 1.75;
    color: rgba(255,255,255,0.5);
    margin-bottom: 24px;
    max-width: 520px;
  }

  .hero-links { display: flex; gap: 12px; flex-wrap: wrap; }

  .hero-link {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 8px;
    font-size: 13px; font-weight: 600;
    text-decoration: none;
    border: 1px solid;
    transition: all 0.2s;
  }
  .link-github {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.7);
  }
  .link-github:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.25);
    color: #fff;
  }
  .link-linkedin {
    background: rgba(10,102,194,0.1);
    border-color: rgba(10,102,194,0.25);
    color: #5ba4cf;
  }
  .link-linkedin:hover {
    background: rgba(10,102,194,0.18);
    border-color: rgba(10,102,194,0.45);
    color: #7bb8e0;
  }
  .link-site {
    background: rgba(0,212,255,0.08);
    border-color: rgba(0,212,255,0.2);
    color: var(--cyan);
  }
  .link-site:hover {
    background: rgba(0,212,255,0.14);
    border-color: rgba(0,212,255,0.4);
  }

  .hero-stats {
    position: relative;
    display: flex; align-items: center;
    padding: 18px 20px;
    background: rgba(8, 8, 24, 0.92);
    border-radius: 12px;
    width: fit-content;
    margin: 4px 0 0 28px;
  }

  /* Rainbow gradient border */
  .hero-stats::before {
    content: '';
    position: absolute;
    inset: -1.5px;
    border-radius: 13.5px;
    background: linear-gradient(90deg,
      #ff4040 0%,
      #ff8c00 18%,
      #ffd700 36%,
      #40c840 50%,
      #00aaff 68%,
      #a040ff 84%,
      #ff4040 100%
    );
    z-index: -1;
  }

  /* Blurred rainbow glow behind the card */
  .hero-stats::after {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 22px;
    background: linear-gradient(90deg,
      rgba(255,64,64,0.55) 0%,
      rgba(255,140,0,0.55) 18%,
      rgba(255,215,0,0.45) 36%,
      rgba(64,200,64,0.45) 50%,
      rgba(0,170,255,0.55) 68%,
      rgba(160,64,255,0.55) 84%,
      rgba(255,64,64,0.55) 100%
    );
    filter: blur(16px);
    z-index: -1;
    opacity: 0.75;
  }

  .stat { display: flex; flex-direction: column; align-items: center; padding: 0 26px; }
  .stat-value { font-size: 20px; font-weight: 800; color: #fff; line-height: 1; }
  .stat-label { font-size: 10px; color: rgba(255,255,255,0.45); margin-top: 3px; letter-spacing: 0.3px; white-space: nowrap; }
  .stat-sep { width: 1px; height: 28px; background: rgba(255,255,255,0.12); }

  /* ── Skills ── */
  .hero-skills {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .skill-group {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    flex-wrap: wrap;
  }
  .group-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    color: rgba(255,255,255,0.22);
    white-space: nowrap;
    min-width: 96px;
    padding-top: 4px;
  }
  .skill-tags { display: flex; gap: 7px; flex-wrap: wrap; }
  .skill-tag {
    font-size: 11px;
    font-weight: 500;
    padding: 4px 11px;
    border-radius: 20px;
    white-space: nowrap;
    transition: opacity 0.2s;
  }
  .skill-tag:hover { opacity: 0.8; }
  .tag-ai   { background: rgba(0,212,255,0.09);   color: var(--cyan);   border: 1px solid rgba(0,212,255,0.2); }
  .tag-eng  { background: rgba(251,146,60,0.09);  color: var(--orange); border: 1px solid rgba(251,146,60,0.2); }
  .tag-data { background: rgba(52,211,153,0.09);  color: var(--green);  border: 1px solid rgba(52,211,153,0.2); }

  /* ── Right column — portrait ── */
  .hero-right {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .portrait-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    margin-right: 24px;
  }

  /* soft ambient glow behind */
  .portrait-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -56%);
    width: 260px;
    height: 260px;
    background: radial-gradient(
      circle,
      rgba(0,212,255,0.28) 0%,
      rgba(168,85,247,0.18) 40%,
      transparent 68%
    );
    filter: blur(32px);
    pointer-events: none;
    border-radius: 50%;
    animation: glow-pulse 4s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%, 100% { opacity: 0.7; transform: translate(-50%, -56%) scale(1); }
    50%       { opacity: 1;   transform: translate(-50%, -56%) scale(1.1); }
  }

  /* container that floats */
  .portrait-frame {
    position: relative;
    width: 224px;
    height: 224px;
    border-radius: 50%;
    animation: float 5s ease-in-out infinite;
    cursor: default;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }

  /* spinning gradient ring — mask cuts out center so background shows through */
  .portrait-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      var(--cyan)   0%,
      var(--purple) 38%,
      rgba(0,212,255,0.04) 62%,
      var(--cyan)   100%
    );
    animation: ring-spin 3.5s linear infinite;
    -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 3px), white calc(100% - 3px));
    mask:         radial-gradient(farthest-side, transparent calc(100% - 3px), white calc(100% - 3px));
    z-index: 2;
  }

  @keyframes ring-spin {
    to { transform: rotate(360deg); }
  }

  /* outer orbit ring — slow pulse */
  .portrait-frame::after {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 1px solid rgba(0,212,255,0.18);
    animation: orbit-pulse 4s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes orbit-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50%       { opacity: 0.8; transform: scale(1.03); }
  }

  /* the photo */
  .portrait-img {
    position: absolute;
    inset: 8px;
    width: calc(100% - 16px);
    height: calc(100% - 16px);
    border-radius: 50%;
    object-fit: cover;
    object-position: center 8%;
    filter: brightness(1.0) saturate(1.08);
    transition: filter 0.35s ease, transform 0.35s ease;
    z-index: 3;
  }

  .portrait-frame:hover .portrait-img {
    filter: brightness(1.06) saturate(1.15);
    transform: scale(1.025);
  }

  .portrait-frame:hover::before {
    animation-duration: 1.8s;
  }

  .portrait-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 20px;
    font-size: 11px;
    color: rgba(255,255,255,0.42);
    letter-spacing: 0.4px;
    backdrop-filter: blur(10px);
    position: relative;
    z-index: 1;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px rgba(52,211,153,0.8);
    flex-shrink: 0;
    animation: dot-blink 2.4s ease-in-out infinite;
  }

  @keyframes dot-blink {
    0%, 100% { opacity: 1;   box-shadow: 0 0 8px rgba(52,211,153,0.8); }
    50%       { opacity: 0.5; box-shadow: 0 0 4px rgba(52,211,153,0.4); }
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 32px;
      margin-bottom: 40px;
      padding: 28px 0 32px;
    }
    .hero-right {
      order: -1;
    }
    .portrait-frame {
      width: 160px;
      height: 160px;
    }
    .hero-left { gap: 32px; }
    .hero-stats {
      flex-wrap: wrap;
      width: calc(100% - 28px);
      margin: 0 14px;
      justify-content: center;
      padding: 16px 12px;
    }
    .hero-stats::after { filter: blur(12px); opacity: 0.6; }
    .stat { padding: 10px 18px; }
    .stat-sep { display: none; }
    .hero-skills {
      margin-top: 20px;
      padding-top: 20px;
      gap: 14px;
    }
    .group-label { min-width: 80px; }
  }
</style>
