---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'zh';
}

const {
  title,
  description = 'Writing by Encore Shao — Full-stack Engineer & AI Researcher',
  lang = 'en',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Encore Shao</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />
    {lang === 'zh'
      ? <link rel="alternate" type="application/rss+xml" title="邵恩科的博客 RSS" href="/zh/rss.xml" />
      : <link rel="alternate" type="application/rss+xml" title="Encore Shao's Blog RSS" href="/rss.xml" />
    }
  </head>
  <body>
    <slot />
  </body>
</html>
